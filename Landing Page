  <script>
    const STORAGE_KEY = 'pmhub_booked_slots';

    function getBookedSlots() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
      catch { return []; }
    }

    function saveBookedSlot(label) {
      const booked = getBookedSlots();
      if (!booked.includes(label)) booked.push(label);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(booked));
    }

    // Remove a slot button from every grid on the page
    function removeSlotEverywhere(label) {
      document.querySelectorAll('.slot').forEach(btn => {
        if (btn.textContent.trim() === label) btn.remove();
      });
    }

    // On page load, remove any already-booked slots from all grids
    function applyBookedSlots() {
      getBookedSlots().forEach(label => removeSlotEverywhere(label));
    }

    function selectSlot(el) {
      const grid = el.closest('.slots-grid');
      grid.querySelectorAll('.slot').forEach(s => s.classList.remove('active'));
      el.classList.add('active');
    }

    function handleSubmit(btn) {
      const formBox = btn.closest('.form-box');
      const activeSlot = formBox.querySelector('.slot.active');

      if (!activeSlot) {
        showToast('Please pick a time slot first.', 'warn');
        return;
      }

      const label = activeSlot.textContent.trim();

      // Save and remove from all grids
      saveBookedSlot(label);
      removeSlotEverywhere(label);

      // Reset the form fields in this box
      formBox.querySelectorAll('input, textarea').forEach(el => el.value = '');

      showToast(`Booked! ${label} has been removed from availability.`, 'success');
    }

    function showToast(msg, type) {
      const existing = document.getElementById('pmhub-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'pmhub-toast';
      toast.textContent = msg;
      toast.style.cssText = `
        position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
        background: ${type === 'success' ? '#e8692a' : '#555'};
        color: #fff; padding: 0.75rem 1.5rem; border-radius: 100px;
        font-family: Inter, sans-serif; font-size: 0.875rem; font-weight: 500;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3); z-index: 9999;
        white-space: nowrap; max-width: 90vw; text-align: center;
        animation: slideUp 0.3s ease;
      `;
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 3500);
    }

    // Add a style for the toast animation
    const style = document.createElement('style');
    style.textContent = `@keyframes slideUp { from { opacity:0; transform: translateX(-50%) translateY(12px); } to { opacity:1; transform: translateX(-50%) translateY(0); } }`;
    document.head.appendChild(style);

    // Run on load
    applyBookedSlots();

    // Generic AJAX form handler for Formspree
    async function submitToFormspree(form, successId, slotHiddenId) {
      const btn = form.querySelector('button[type="submit"]');
      const successMsg = document.getElementById(successId);

      // If form has a slot grid, make sure one is selected
      const grid = form.querySelector('.slots-grid');
      if (grid) {
        const activeSlot = grid.querySelector('.slot.active');
        if (!activeSlot) {
          showToast('Please pick a time slot first.', 'warn');
          return;
        }
        // Write slot label into hidden field
        document.getElementById(slotHiddenId).value = activeSlot.textContent.trim();
      }

      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          // If there was a slot, remove it from all grids and save to storage
          if (grid) {
            const slotLabel = document.getElementById(slotHiddenId).value;
            saveBookedSlot(slotLabel);
            removeSlotEverywhere(slotLabel);
          }
          form.reset();
          successMsg.style.display = 'block';
          btn.textContent = 'Sent!';
          btn.style.background = '#b84f1a';
        } else {
          btn.textContent = 'Something went wrong. Try again.';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Something went wrong. Try again.';
        btn.disabled = false;
      }
    }

    // Wire up all three forms
    document.getElementById('join-form').addEventListener('submit', function(e) {
      e.preventDefault();
      submitToFormspree(this, 'join-success', null);
    });

    document.getElementById('chat-form').addEventListener('submit', function(e) {
      e.preventDefault();
      submitToFormspree(this, 'chat-success', 'chat-slot-value');
    });

    document.getElementById('member-form').addEventListener('submit', function(e) {
      e.preventDefault();
      submitToFormspree(this, 'member-success', 'member-slot-value');
    });
  </script>
